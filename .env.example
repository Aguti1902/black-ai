# Copy to .env.local for local development.
# On Vercel: Project Settings → Environment Variables → add both keys, then redeploy.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional — contact form via EmailJS
VITE_EMAILJS_SERVICE=service_xxxxx
VITE_EMAILJS_TEMPLATE=template_xxxxx
VITE_EMAILJS_KEY=your_public_key
